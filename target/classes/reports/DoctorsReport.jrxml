              name="DoctorsReport" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    
    <queryString language="SQL">
        <![CDATA[SELECT Id, Name, Specialty, Phone_Number, Email, Gender, Years_of_Experience, Status, Start_Time, End_Time FROM doctors]]>
